<Window x:Class="SimpleCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpleCalculator"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Simple calulator" MinHeight="380" MinWidth="250" Height="400" Width="480" Background="#202020">

    <Window.Resources>

        <!-- Анимация открытия -->
        <Storyboard x:Key="ShowHistory">
            <DoubleAnimation
                Storyboard.TargetName="HistoryPanel"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                To="0"
                Duration="0:0:0.25"/>
        </Storyboard>

        <!-- Анимация закрытия -->
        <Storyboard x:Key="HideHistory">
            <DoubleAnimation
                Storyboard.TargetName="HistoryPanel"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                To="300"
                Duration="0:0:0.25"/>
        </Storyboard>

    </Window.Resources>

    <Grid>

        <!-- ОСНОВНОЙ UI -->
        <Grid Margin="0 5 0 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="4*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- КНОПКА ИСТОРИИ -->
            <Button Margin="5 0 0 0" Grid.Row="0" Grid.Column="0" Style="{StaticResource TransparentButtonStyle}" Width="35" HorizontalAlignment="Left" Click="HistoryButton_Click">
                <Image Margin="8" Source="{StaticResource HistoryImage}"/>
                    <Canvas Width="24" Height="24">
                        <Path Fill="#FFEEEEEE" Data="F1 M24,24z M0,0z M12,24C5.4,24,0,18.6,0,12L2,12C2,17.5 6.5,22 12,22 17.5,22 22,17.5 22,12 22,6.5 17.5,2 12,2 8.4,2 5.1,3.9 3.3,7L8,7 8,9 0,9 0,1 2,1 2,5.4C4.2,2.1 8,0 12,0 18.6,0 24,5.4 24,12 24,18.6 18.6,24 12,24z M15.3,17.8L11,13.4 11,6 13,6 13,12.6 16.7,16.4 15.3,17.8z" />
                    </Canvas>
                </Viewbox>
            </Button>

            <TextBlock Grid.Column="1" d:Text= "8 + 3 =" Text="{Binding CalculationString}" Margin="0 0 5 0" Foreground="LightGray" TextAlignment="Right" VerticalAlignment="Center" FontSize="18"/>

            <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0 0 5 0" Text="{Binding Result}" Style="{StaticResource DefaultTextBoxStyle}" />

            <UniformGrid Grid.Row="3" Grid.Column="0" Columns="3">
                <Button Content="1" Command="{Binding SymbolCommand}" CommandParameter="1" Style="{StaticResource DefaultButtonStyle}"/>
                <Button Content="2" Command="{Binding SymbolCommand}" CommandParameter="2" Style="{StaticResource DefaultButtonStyle}"/>
                <Button Content="3" Command="{Binding SymbolCommand}" CommandParameter="3" Style="{StaticResource DefaultButtonStyle}"/>
                <Button Content="4" Command="{Binding SymbolCommand}" CommandParameter="4" Style="{StaticResource DefaultButtonStyle}"/>
                <Button Content="5" Command="{Binding SymbolCommand}" CommandParameter="5" Style="{StaticResource DefaultButtonStyle}"/>
                <Button Content="6" Command="{Binding SymbolCommand}" CommandParameter="6" Style="{StaticResource DefaultButtonStyle}"/>
                <Button Content="7" Command="{Binding SymbolCommand}" CommandParameter="7" Style="{StaticResource DefaultButtonStyle}"/>
                <Button Content="8" Command="{Binding SymbolCommand}" CommandParameter="8" Style="{StaticResource DefaultButtonStyle}"/>
                <Button Content="9" Command="{Binding SymbolCommand}" CommandParameter="9" Style="{StaticResource DefaultButtonStyle}"/>
                <Button Content="." Command="{Binding SymbolCommand}" CommandParameter="." Style="{StaticResource DefaultButtonStyle}"/>
                <Button Content="0" Command="{Binding SymbolCommand}" CommandParameter="0" Style="{StaticResource DefaultButtonStyle}"/>
                <Button Content="C" Command="{Binding ClearCommand}" Style="{StaticResource DefaultButtonStyle}"/>
            </UniformGrid>

            <UniformGrid Grid.Row="2" Grid.ColumnSpan="2" Rows="1">
                <Button Content="+" Command="{Binding OperationCommand}" CommandParameter="+" Style="{StaticResource OperationButtonStyle}"/>
                <Button Content="-" Command="{Binding OperationCommand}" CommandParameter="-" Style="{StaticResource OperationButtonStyle}"/>
                <Button Content="*" Command="{Binding OperationCommand}" CommandParameter="*" Style="{StaticResource OperationButtonStyle}"/>
                <Button Content="/" Command="{Binding OperationCommand}" CommandParameter="/" Style="{StaticResource OperationButtonStyle}"/>
            </UniformGrid>

            <Grid Grid.Row="3" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="3*"/>
                </Grid.RowDefinitions>
                <Button Grid.Row="0" Content="+/-" Command="{Binding SignCommand}" Style="{StaticResource DefaultButtonStyle}"/>
                <Button Grid.Row="1" Content="=" Command="{Binding CalculateCommand}" Style="{StaticResource CalculateButtonStyle}"/>
            </Grid>
        </Grid>

        <!-- ЗАТЕМНЕНИЕ -->
        <Border x:Name="Overlay"
                Background="#80000000"
                Visibility="Collapsed"
                MouseDown="Overlay_MouseDown"/>

        <!-- ПАНЕЛЬ ИСТОРИИ -->
        <Border x:Name="HistoryPanel"
                Background="#2B2B2B"
                Height="300"
                VerticalAlignment="Bottom"
                CornerRadius="12,12,0,0">

            <Border.RenderTransform>
                <TranslateTransform Y="300"/>
            </Border.RenderTransform>

            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.3"/>
            </Border.Effect>

            <ListBox ItemsSource="{Binding History}"
                     Foreground="White"
                     Background="Transparent"
                     BorderThickness="0"
                     Margin="10"/>
        </Border>

    </Grid>
</Window>