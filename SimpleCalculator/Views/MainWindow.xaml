<Window x:Class="SimpleCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpleCalculator"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Simple calulator" MinHeight="380" MinWidth="250" Height="400" Width="480" Background="#212020">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Result}" Style="{StaticResource DefaultTextBoxStyle}" />

        <UniformGrid Grid.Row="2" Grid.Column="0" Columns="3">
            <Button Content="1" Command="{Binding SymbolCommand}" CommandParameter="1" Style="{StaticResource DefaultButtonStyle}"/>
            <Button Content="2" Command="{Binding SymbolCommand}" CommandParameter="2" Style="{StaticResource DefaultButtonStyle}"/>
            <Button Content="3" Command="{Binding SymbolCommand}" CommandParameter="3" Style="{StaticResource DefaultButtonStyle}"/>
            <Button Content="4" Command="{Binding SymbolCommand}" CommandParameter="4" Style="{StaticResource DefaultButtonStyle}"/>
            <Button Content="5" Command="{Binding SymbolCommand}" CommandParameter="5" Style="{StaticResource DefaultButtonStyle}"/>
            <Button Content="6" Command="{Binding SymbolCommand}" CommandParameter="6" Style="{StaticResource DefaultButtonStyle}"/>
            <Button Content="7" Command="{Binding SymbolCommand}" CommandParameter="7" Style="{StaticResource DefaultButtonStyle}"/>
            <Button Content="8" Command="{Binding SymbolCommand}" CommandParameter="8" Style="{StaticResource DefaultButtonStyle}"/>
            <Button Content="9" Command="{Binding SymbolCommand}" CommandParameter="9" Style="{StaticResource DefaultButtonStyle}"/>
            <Button Content="." Command="{Binding SymbolCommand}" CommandParameter="." Style="{StaticResource DefaultButtonStyle}"/>
            <Button Content="0" Command="{Binding SymbolCommand}" CommandParameter="0" Style="{StaticResource DefaultButtonStyle}"/>
            <Button Content="C" Command="{Binding ClearCommand}" Style="{StaticResource DefaultButtonStyle}"/>
        </UniformGrid>

        <UniformGrid Grid.Row="1" Grid.ColumnSpan="2" Rows="1">
            <Button Content="+" Command="{Binding OperationCommand}" CommandParameter="+" Style="{StaticResource OperationButtonStyle}"/>
            <Button Content="-" Command="{Binding OperationCommand}" CommandParameter="-" Style="{StaticResource OperationButtonStyle}"/>
            <Button Content="*" Command="{Binding OperationCommand}" CommandParameter="*" Style="{StaticResource OperationButtonStyle}"/>
            <Button Content="/" Command="{Binding OperationCommand}" CommandParameter="/" Style="{StaticResource OperationButtonStyle}"/>
        </UniformGrid>

        <Button Grid.Column="2" Grid.Row="2" Content="=" Command="{Binding CalculateCommand}" Style="{StaticResource CalculateButtonStyle}"/>

    </Grid>
</Window>
